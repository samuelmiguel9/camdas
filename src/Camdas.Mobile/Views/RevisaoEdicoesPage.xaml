<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Camdas.Mobile.Views.RevisaoEdicoesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Camdas.Mobile.ViewModels;assembly=Camdas.Mobile.Core"
    xmlns:contracts="clr-namespace:Camdas.Contracts;assembly=Camdas.Contracts"
    x:DataType="vm:RevisaoEdicoesViewModel"
    Title="Edições pendentes (Web)">

    <Grid Padding="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">

        <Button Grid.Row="0" Text="Atualizar" Command="{Binding RecarregarCommand}" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Itens}">
            <CollectionView.EmptyView>
                <Label Text="Nenhuma edição pendente." HorizontalOptions="Center" VerticalOptions="Center" TextColor="Gray" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="contracts:EdicaoPendenteDto">
                    <Border Margin="0,4" Padding="12" Stroke="#DDDDDD" StrokeShape="RoundRectangle 6">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding TipoOperacao}" FontAttributes="Bold" />
                            <Label Text="{Binding DadosDepoisJson}" FontSize="12" TextColor="Gray" />
                            <Label Text="{Binding Responsavel, StringFormat='Responsável: {0}'}" />
                            <Label Text="{Binding Motivo, StringFormat='Motivo: {0}'}" />
                            <Label Text="{Binding DataSolicitacao, StringFormat='Solicitado em {0:dd/MM/yyyy HH:mm}'}" FontSize="12" TextColor="Gray" />

                            <HorizontalStackLayout Spacing="8" Margin="0,8,0,0">
                                <Button Text="Aprovar" BackgroundColor="#2E7D32" TextColor="White"
                                        Clicked="OnAprovarClicked" CommandParameter="{Binding .}" />
                                <Button Text="Rejeitar" BackgroundColor="#C62828" TextColor="White"
                                        Clicked="OnRejeitarClicked" CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="2" Text="{Binding MensagemErro}" TextColor="Red" />
    </Grid>
</ContentPage>
