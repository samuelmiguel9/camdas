<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Camdas.Mobile.Views.HistoricoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Camdas.Mobile.ViewModels;assembly=Camdas.Mobile.Core"
    xmlns:contracts="clr-namespace:Camdas.Contracts;assembly=Camdas.Contracts"
    x:DataType="vm:HistoricoViewModel"
    Title="Histórico e versões">

    <Grid Padding="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">

        <Button Grid.Row="0" Text="Atualizar" Command="{Binding RecarregarCommand}" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Itens}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="contracts:HistoricoDto">
                    <Grid Padding="8" ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Acao}" />
                        <Label Grid.Column="1" Text="{Binding DataHora, StringFormat='{0:dd/MM/yyyy HH:mm}'}" TextColor="Gray" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="2" Text="{Binding MensagemErro}" TextColor="Red" />
    </Grid>
</ContentPage>
