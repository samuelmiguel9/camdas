<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Camdas.Mobile.Views.CamadaEdicaoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Camdas.Mobile.ViewModels;assembly=Camdas.Mobile.Core"
    xmlns:views="clr-namespace:Camdas.Mobile.Views"
    x:DataType="vm:CamadaEdicaoViewModel"
    Title="{Binding Camada.Nome}">

    <Grid Padding="8" RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="6">

        <!-- Barra de ferramentas no topo, estilo SketchBook: ícones centralizados, fundo claro. -->
        <Border Grid.Row="0" StrokeShape="RoundRectangle 8" Stroke="#D8D0C0" BackgroundColor="#F5F1E8"
                Padding="10,4" HorizontalOptions="Center">
            <HorizontalStackLayout Spacing="14">
                <Button Text="↶" FontSize="20" Padding="6,0" BackgroundColor="Transparent" TextColor="#333"
                        Clicked="OnDesfazerClicked" />
                <Button Text="↷" FontSize="20" Padding="6,0" BackgroundColor="Transparent" TextColor="#333"
                        Clicked="OnRefazerClicked" />
                <BoxView WidthRequest="1" HeightRequest="24" Color="#D8D0C0" />
                <Button x:Name="BotaoTexto" Text="T" FontSize="18" FontAttributes="Bold" Padding="8,0"
                        BackgroundColor="Transparent" TextColor="#333" Clicked="OnAlternarModoTextoClicked" />
                <Button x:Name="BotaoPan" Text="✋" FontSize="18" Padding="8,0"
                        BackgroundColor="Transparent" TextColor="#333" Clicked="OnAlternarModoPanClicked" />
            </HorizontalStackLayout>
        </Border>

        <!-- Zoom: mesmo controle da tela de visualização (PlantaPage) — aqui o traço é sempre
             armazenado na resolução nativa da planta (Canvas.UsarResolucaoNativa=true, definido no
             code-behind), então desenhar com zoom não distorce nem depende do tamanho da tela do
             aparelho. -->
        <HorizontalStackLayout Grid.Row="1" Spacing="8">
            <Label Text="Zoom" VerticalOptions="Center" />
            <Button Text="−" WidthRequest="36" Clicked="OnDiminuirZoomClicked" />
            <Slider x:Name="ZoomSlider" Minimum="0.25" Maximum="3" Value="1" WidthRequest="120"
                    VerticalOptions="Center" ValueChanged="OnZoomSliderChanged" />
            <Button Text="+" WidthRequest="36" Clicked="OnAumentarZoomClicked" />
            <Label x:Name="ZoomLabel" Text="100%" VerticalOptions="Center" WidthRequest="48" />
        </HorizontalStackLayout>

        <!-- Sem ScrollView de propósito: um ScrollView ao redor do canvas competia com o próprio
             gesto de desenhar (arrastar o dedo virava rolagem do ScrollView pai a partir do primeiro
             Moved, travando o traço no ponto inicial mesmo com RequestDisallowInterceptTouchEvent).
             Pan é um modo explícito (botão ✋ na barra acima): só nesse modo arrastar move a
             visualização — desligado, o toque desenha normalmente. Nunca os dois ao mesmo tempo. -->
        <Grid Grid.Row="2">

            <views:PlantaCanvasView
                x:Name="Canvas"
                Camadas="{Binding Camadas}"
                ImagemBase="{Binding ImagemBase}"
                ImagensPorCamada="{Binding ImagensPorCamada}"
                CamadaAtivaId="{Binding Camada.Id}"
                CorTraco="{Binding CorTraco}"
                EspessuraTraco="{Binding EspessuraTraco}"
                ModoApagar="{Binding ModoApagar}" />
        </Grid>

        <VerticalStackLayout Grid.Row="3" Spacing="4">
            <HorizontalStackLayout Spacing="6">
                <Button BackgroundColor="#000000" WidthRequest="32" HeightRequest="32" CommandParameter="#000000" Clicked="OnCorClicked" />
                <Button BackgroundColor="#E74C3C" WidthRequest="32" HeightRequest="32" CommandParameter="#E74C3C" Clicked="OnCorClicked" />
                <Button BackgroundColor="#E67E22" WidthRequest="32" HeightRequest="32" CommandParameter="#E67E22" Clicked="OnCorClicked" />
                <Button BackgroundColor="#F1C40F" WidthRequest="32" HeightRequest="32" CommandParameter="#F1C40F" Clicked="OnCorClicked" />
                <Button BackgroundColor="#2ECC71" WidthRequest="32" HeightRequest="32" CommandParameter="#2ECC71" Clicked="OnCorClicked" />
                <Button BackgroundColor="#2E86DE" WidthRequest="32" HeightRequest="32" CommandParameter="#2E86DE" Clicked="OnCorClicked" />
                <Button BackgroundColor="#8E44AD" WidthRequest="32" HeightRequest="32" CommandParameter="#8E44AD" Clicked="OnCorClicked" />
                <Button BackgroundColor="#7F8C8D" WidthRequest="32" HeightRequest="32" CommandParameter="#7F8C8D" Clicked="OnCorClicked" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="6">
                <Label Text="Espessura" VerticalOptions="Center" />
                <Slider Minimum="2" Maximum="{Binding EspessuraMaxima}" Value="{Binding EspessuraTraco, Mode=TwoWay}" WidthRequest="120" VerticalOptions="Center" />
                <Label Text="Apagar" VerticalOptions="Center" />
                <Switch IsToggled="{Binding ModoApagar, Mode=TwoWay}" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="8">
                <Button Text="Limpar" Clicked="OnLimparClicked" />
                <Button Text="Salvar camada" Command="{Binding SalvarCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <Label Grid.Row="4" Text="{Binding MensagemErro}" TextColor="Red" />
    </Grid>
</ContentPage>
