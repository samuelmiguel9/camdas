<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Camdas.Mobile.Views.PlantaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Camdas.Mobile.ViewModels;assembly=Camdas.Mobile.Core"
    xmlns:contracts="clr-namespace:Camdas.Contracts;assembly=Camdas.Contracts"
    xmlns:views="clr-namespace:Camdas.Mobile.Views"
    x:DataType="vm:PlantaViewModel"
    Title="Planta">

    <Grid Padding="8" RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" RowSpacing="6">

        <HorizontalStackLayout Grid.Row="0" Spacing="8">
            <Button Text="Histórico" Clicked="OnAbrirHistoricoClicked" />
            <Button Text="⏳ Edições pendentes (Web)" Clicked="OnAbrirEdicoesPendentesClicked" />
        </HorizontalStackLayout>

        <!-- Controle de zoom da visualização geral (só esta tela — a tela de desenho de camada
             continua com o encaixe automático de sempre, ver comentário em PlantaCanvasView.Zoom). -->
        <HorizontalStackLayout Grid.Row="1" Spacing="8">
            <Label Text="Zoom" VerticalOptions="Center" />
            <Button Text="−" WidthRequest="36" Clicked="OnDiminuirZoomClicked" />
            <Slider x:Name="ZoomSlider" Minimum="0.25" Maximum="3" Value="1" WidthRequest="140"
                    VerticalOptions="Center" ValueChanged="OnZoomSliderChanged" />
            <Button Text="+" WidthRequest="36" Clicked="OnAumentarZoomClicked" />
            <Label x:Name="ZoomLabel" Text="100%" VerticalOptions="Center" WidthRequest="48" />
            <Button Text="Ajustar" Clicked="OnAjustarZoomClicked" />
        </HorizontalStackLayout>

        <!-- Só visualização: mostra a imagem da planta + o traço de cada camada visível, tudo
             junto. O desenho em si acontece na tela isolada de cada camada (toque no nome abaixo).
             ScrollView permite ver/percorrer a planta inteira quando o zoom deixa o conteúdo maior
             que a tela; linha com peso 7* (contra 2* da lista de camadas) pra a planta não ficar
             cortada. -->
        <ScrollView Grid.Row="2" Orientation="Both">
            <views:PlantaCanvasView
                x:Name="Canvas"
                Camadas="{Binding Camadas}"
                ImagemBase="{Binding ImagemBase}"
                ImagensPorCamada="{Binding ImagensPorCamada}" />
        </ScrollView>

        <HorizontalStackLayout Grid.Row="3" Spacing="8">
            <!-- Oculta a lista de camadas por padrão (deixa mais espaço pra planta) — clique mostra/
                 esconde; a seta indica o estado (▲ mostra, ▼ esconde), igual um "drawer". -->
            <Button x:Name="BotaoAlternarCamadas" Text="▲ Camadas" FontAttributes="Bold" Clicked="OnAlternarCamadasClicked" />
            <Button Text="+ Nova camada" Clicked="OnNovaCamadaClicked" />
            <Button Text="+ Imagem" Clicked="OnAdicionarImagemClicked" />
            <Button Text="💾 Salvar tudo (PNG)" Clicked="OnSalvarNaGaleriaClicked" />
        </HorizontalStackLayout>

        <!-- Painel estilo Photoshop: fundo escuro, olho (visibilidade), miniatura em xadrez (toque
             abre o menu de opções da camada), nome, cadeado (só indicador — o botão foi para o
             menu). A própria linha é arrastável (DragGestureRecognizer/DropGestureRecognizer) pra
             reordenar soltando sobre outra camada, ou soltando na lixeira ao lado pra excluir.
             Oculto por padrão (IsVisible=False) — ver BotaoAlternarCamadas; HeightRequest limita a
             altura quando aberto, pra não empurrar o canvas pra fora da tela, com scroll próprio. -->
        <Grid x:Name="PainelCamadas" Grid.Row="4" ColumnDefinitions="*,44" ColumnSpacing="6"
              HeightRequest="220" IsVisible="False">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 4" Stroke="#1E1E1E" BackgroundColor="#2E2E2E" Padding="0">
                <CollectionView ItemsSource="{Binding Camadas}" BackgroundColor="Transparent">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="contracts:CamadaDto">
                            <Grid Padding="6,4" ColumnDefinitions="32,36,*,24" ColumnSpacing="6" RowDefinitions="Auto" BackgroundColor="Transparent">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.SelecionarCamadaCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}" />
                                    <DragGestureRecognizer CanDrag="True" DragStarting="OnCamadaDragStarting" />
                                    <DropGestureRecognizer AllowDrop="True" Drop="OnCamadaDrop" />
                                </Grid.GestureRecognizers>

                                <!-- Olho: sempre mostra um glifo (aberto/fechado) pra permanecer visível e clicável
                                     mesmo com a camada oculta — antes sumia por completo e ficava impossível achar
                                     o botão pra reexibir a camada. -->
                                <Button Grid.Column="0" Text="{Binding Visivel, Converter={StaticResource BoolParaTextoConverter}, ConverterParameter='👁;🚫'}"
                                        FontSize="16" TextColor="#DCDCDC" BackgroundColor="Transparent" Padding="0" BorderWidth="0"
                                        Command="{Binding BindingContext.AlternarVisibilidadeCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}" />

                                <views:CamadaThumbnailView Grid.Column="1" WidthRequest="32" HeightRequest="32"
                                        CamadaId="{Binding Id}"
                                        ImagensPorCamada="{Binding BindingContext.ImagensPorCamada, Source={RelativeSource AncestorType={x:Type ContentPage}}}">
                                    <views:CamadaThumbnailView.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.AbrirMenuCamadaCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                            CommandParameter="{Binding .}" />
                                    </views:CamadaThumbnailView.GestureRecognizers>
                                </views:CamadaThumbnailView>

                                <VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="{Binding Nome}" TextColor="#DCDCDC" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                        <Label Text="🔒" FontSize="11" TextColor="#DCDCDC" VerticalOptions="Center"
                                               IsVisible="{Binding Bloqueada}" />
                                        <Label Text="🔐" FontSize="11" TextColor="#DCDCDC" VerticalOptions="Center"
                                               IsVisible="{Binding BloqueioAlpha}"
                                               ToolTipProperties.Text="Opacidade bloqueada" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Alça visual: indica que a linha pode ser arrastada pra reordenar/excluir. -->
                                <Label Grid.Column="3" Text="⠿" FontSize="14" TextColor="#777777"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <!-- Lixeira: solte uma camada arrastada aqui pra excluí-la. -->
            <Border Grid.Column="1" StrokeShape="RoundRectangle 4" Stroke="#1E1E1E" BackgroundColor="#3A2323" Padding="0">
                <Border.GestureRecognizers>
                    <DropGestureRecognizer AllowDrop="True" Drop="OnCamadaDropNaLixeira" />
                </Border.GestureRecognizers>
                <Label Text="🗑" FontSize="20" TextColor="#E74C3C" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

        <Label Grid.Row="5" Text="{Binding MensagemErro}" TextColor="Red" />

        <!-- Menu de opções da camada, aberto ao tocar a miniatura: opacidade, limpar (sem excluir a
             camada), bloqueio, bloqueio de opacidade, duplicar, excluir. Grid.RowSpan cobre a tela
             inteira e fica por cima de tudo por ser o último filho do Grid raiz. -->
        <Grid Grid.Row="0" Grid.RowSpan="6" BackgroundColor="#AA000000"
              IsVisible="{Binding CamadaMenuAberta, Converter={StaticResource ObjetoNuloParaBoolConverter}, ConverterParameter=inverso}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding FecharMenuCamadaCommand}" />
            </Grid.GestureRecognizers>

            <!-- MaximumHeightRequest + ScrollView: com os 8 itens do menu, o conteúdo podia ficar mais
                 alto que a tela — e como o Border fica centralizado verticalmente sem rolagem, o
                 excesso "vazava" pros dois lados por igual, cortando o topo (Nome + Opacidade) e o
                 rodapé (bug relatado: "a opacidade das camadas sumiu", era só o topo do menu cortado). -->
            <Border Padding="16" Margin="24" BackgroundColor="#2E2E2E" Stroke="#1E1E1E" StrokeShape="RoundRectangle 8"
                    VerticalOptions="Center" HorizontalOptions="Fill" MaximumHeightRequest="480">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>

                <ScrollView>
                    <VerticalStackLayout Spacing="12" BindingContext="{Binding CamadaMenuAberta}" x:DataType="contracts:CamadaDto">
                        <Label Text="{Binding Nome}" FontAttributes="Bold" FontSize="16" TextColor="White" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Opacidade" TextColor="#CCCCCC" FontSize="12" />
                            <Slider Minimum="0" Maximum="1" Value="{Binding Opacidade, Mode=TwoWay}"
                                    DragCompleted="OnOpacidadeSliderDragCompleted" />
                        </VerticalStackLayout>

                        <Button Text="Limpar camada"
                                Command="{Binding BindingContext.LimparCamadaCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                CommandParameter="{Binding .}" />

                        <Button Text="{Binding Bloqueada, Converter={StaticResource BoolParaTextoConverter}, ConverterParameter='Desbloquear camada;Bloquear camada'}"
                                Command="{Binding BindingContext.AlternarBloqueioCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                CommandParameter="{Binding .}" />

                        <Button Text="{Binding BloqueioAlpha, Converter={StaticResource BoolParaTextoConverter}, ConverterParameter='Desbloquear opacidade;Bloquear opacidade'}"
                                Command="{Binding BindingContext.AlternarBloqueioAlphaCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                CommandParameter="{Binding .}" />

                        <Button Text="Duplicar camada"
                                Command="{Binding BindingContext.DuplicarCamadaCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                CommandParameter="{Binding .}" />

                        <Button Text="Excluir camada" TextColor="#E74C3C"
                                CommandParameter="{Binding .}" Clicked="OnExcluirCamadaClicked" />

                        <Button Text="Fechar"
                                Command="{Binding BindingContext.FecharMenuCamadaCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" />
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
