    private void OnDesenhoAlterado()
    {
        // Qual camada mudou não é informado (pode ser a ativa OU a de Ícones) — mais simples e barato
        // invalidar a miniatura de todas do que tentar adivinhar qual. O ganho real está em NÃO
        // recalcular em renders que não mudam pixel nenhum (ver comentário em MiniaturaCamada).
        _miniaturaCache.Clear();
        StateHasChanged();
    }

    private readonly Dictionary<Guid, string?> _miniaturaCache = [];

    /// <summary>Miniatura em xadrez (indica transparência) + traço da camada, mantendo proporção —
    /// mesmo espírito visual do painel de camadas do Photoshop. Cacheada por camada: sem isto, TODA
    /// miniatura de TODA camada era recalculada (resize + encode PNG + base64) a cada render de
    /// Planta.razor — inclusive em renders que não mudam pixel nenhum, como mexer no slider de
    /// espessura/cor ou arrastar o zoom — um custo real por trás do "delay ao usar as ferramentas"
    /// reportado. O cache só é limpo quando o traço de alguma camada realmente muda (ver
    /// OnDesenhoAlterado/ExcluirCamadaAsync).</summary>
    private string? MiniaturaCamada(Guid camadaId)
    {
        if (_miniaturaCache.TryGetValue(camadaId, out var cacheada))
            return cacheada;

        var resultado = CalcularMiniaturaCamada(camadaId);
        _miniaturaCache[camadaId] = resultado;
        return resultado;
    }

    private string? CalcularMiniaturaCamada(Guid camadaId)
    {
        if (!ViewModel.ImagensPorCamada.TryGetValue(camadaId, out var bitmap))
            return null;

        const int tamanho = 32;
        var escala = (float)tamanho / Math.Max(bitmap.Width, bitmap.Height);
        using var reduzida = bitmap.Resize(
            new SKImageInfo(Math.Max(1, (int)(bitmap.Width * escala)), Math.Max(1, (int)(bitmap.Height * escala))),
            SKFilterQuality.Medium);
        if (reduzida is null)
            return null;

        using var imagem = SKImage.FromBitmap(reduzida);
        using var dados = imagem.Encode(SKEncodedImageFormat.Png, 90);
        return $"data:image/png;base64,{Convert.ToBase64String(dados.ToArray())}";
    }

    private void AoPropriedadeMudar(object? remetente, System.ComponentModel.PropertyChangedEventArgs args)
    {
        InvokeAsync(StateHasChanged);
        if (args.PropertyName == nameof(ViewModel.ImagemBase))
            InvokeAsync(() => _canvasView?.Invalidate());
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= AoPropriedadeMudar;
        _dotNetRef?.Dispose();
    }
