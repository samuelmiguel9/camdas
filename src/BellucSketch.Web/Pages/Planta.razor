    /// <summary>Aba "Edição" da barra de ações — entra no modo de desenho sem exigir que o usuário
    /// primeiro clique no lápis de uma camada específica (reaproveita a última ativa ou a primeira
    /// desbloqueada, ver EntrarEmModoEdicao). O lápis por camada continua existindo pra TROCAR de
    /// camada depois de já estar em edição.</summary>
    private async Task AtivarEdicaoAsync()
    {
        ViewModel.EntrarEmModoEdicao();
        await JS.InvokeVoidAsync("camdasInterop.definirModoDesenho", "planta-canvas-wrapper", true);
    }

    private Task AtivarVisualizacaoAsync() => SairDaEdicaoAsync();

    /// <summary>Baixa a composição atual (imagem base + todas as camadas visíveis, resolução nativa,
    /// sem zoom) como PNG — não existia nenhuma forma de exportar a planta como imagem simples pra
    /// compartilhar fora do app.</summary>
    private async Task BaixarImagemAsync()
    {
        if (ViewModel.ImagemBase is not { } imagemBase)
            return;

        using var composicao = new SKBitmap(imagemBase.Width, imagemBase.Height);
        using (var canvas = new SKCanvas(composicao))
            PlantaOverlayRenderer.Desenhar(canvas, ViewModel.Camadas, ViewModel.ImagemBase, ViewModel.ImagensPorCamada);

        using var imagem = SKImage.FromBitmap(composicao);
        using var dados = imagem.Encode(SKEncodedImageFormat.Png, 100);
        var nomeArquivo = $"{ViewModel.Planta?.Nome ?? "planta"}.png";
        await JS.InvokeVoidAsync("camdasInterop.baixarArquivo", nomeArquivo, Convert.ToBase64String(dados.ToArray()));
    }

    private async Task ExcluirPlantaAsync()
    {
        if (ViewModel.Planta is not { } planta)
            return;

        var confirmar = await JS.InvokeAsync<bool>("confirm", $"Excluir a planta '{planta.Nome}'? Todas as camadas e o traço delas somem, sem volta.");
        if (!confirmar)
            return;

        await ViewModel.ExcluirPlantaAsync();
        Navegacao.NavigateTo($"projetos/{planta.ProjetoId}/plantas");
    }

