@page "/plantas/{PlantaId:guid}"
@using BellucSketch.Mobile.Rendering
@using BellucSketch.Mobile.Services
@using BellucSketch.Mobile.ViewModels
@using BellucSketch.Web.Rendering
@using BellucSketch.Web.Services
@implements IDisposable
@inject PlantaViewModel ViewModel
@inject IJSRuntime JS
@inject IOcrService OcrService
@inject IconeSvgCatalogoWeb IconeCatalogo
@inject NavigationManager Navegacao
@using SkiaSharp
@using SkiaSharp.Views.Blazor

<PageTitle>@(ViewModel.Planta?.Nome ?? "Planta") — BellucSketch</PageTitle>

<h1>@(ViewModel.Planta?.Nome ?? "Carregando...")</h1>

@if (ViewModel.Planta is not null)
{
    <!-- Resumo de auditoria (quem criou/modificou por último e quando) — pedido do usuário: hoje só
         Android mostrava a data de criação, isolada, sem autor nem última modificação. Formatação
         compartilhada com o Android via PlantaViewModel.ResumoAuditoria (Mobile.Core), montada a
         partir do que ObterPlantaQueryHandler já resolve (histórico de auditoria existente). -->
    <p class="planta-auditoria">@ViewModel.ResumoAuditoria</p>
}

@if (ViewModel.MensagemErro is not null)
{
    <p class="text-danger">@ViewModel.MensagemErro</p>
}

@if (ViewModel.Planta is not null)
{
    <!-- Barra de ações da planta: aba Visualização/Edição (era só um "entrar" implícito ao clicar no
         lápis de uma camada, sem nenhum ponto único e óbvio pra alternar) + Baixar/Excluir, que antes
         só existiam espalhados (Excluir só na lista de plantas do projeto; Baixar não existia). -->
    <div class="planta-acoes-barra">
        <div class="planta-abas">
            <button class="@(!ViewModel.ModoEdicao ? "aba-ativa" : "")" @onclick="AtivarVisualizacaoAsync">👁 Visualização</button>
            <button class="@(ViewModel.ModoEdicao ? "aba-ativa" : "")" @onclick="AtivarEdicaoAsync">✏️ Edição</button>
        </div>
        <div class="planta-acoes">
            <button @onclick="BaixarImagemAsync" title="Baixar a planta com todas as camadas visíveis, como PNG">⬇ Baixar</button>
            <button class="planta-acao-excluir" @onclick="ExcluirPlantaAsync" title="Excluir esta planta">🗑 Excluir planta</button>
        </div>
    </div>
}

<div class="planta-layout">
    <div class="planta-area">
        @if (ViewModel.ImagemBase is not null)
        {
            <div class="planta-zoom-controles">
                <span>Zoom</span>
                <button @onclick="() => AjustarZoom(_zoom - 0.25)">−</button>
                <input type="range" min="@ZoomMinimo.ToString(System.Globalization.CultureInfo.InvariantCulture)" max="3" step="0.01" value="@_zoom.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                       @oninput="e => AjustarZoom(double.Parse((string)e.Value!, System.Globalization.CultureInfo.InvariantCulture))" />
                <button @onclick="() => AjustarZoom(_zoom + 0.25)">+</button>
                <span class="planta-zoom-valor">@($"{_zoom:P0}")</span>
                <button @onclick="() => AjustarZoomParaTelaAsync(telaCheia: false)">Ajustar à tela</button>
                <button @onclick="AbrirTelaCheia" title="Abrir em tela cheia">⛶ Ampliar</button>
            </div>

            @if (ViewModel.ModoEdicao)
            {
                <div class="planta-edicao-toolbar">
                    <div class="edicao-grupo edicao-camada-ativa">
                        <!-- Antes só dava pra trocar de camada indo até o painel lateral (clicando no
                             lápis de cada linha) — o usuário pediu um jeito direto, na própria barra de
                             ferramentas, de ver/trocar em qual camada o traço está caindo, sem precisar
                             rolar até o painel (igual o Android, onde tocar em qualquer parte da linha da
                             camada já seleciona ela pra edição). -->
                        <label for="select-camada-ativa">Editando:</label>
                        <select id="select-camada-ativa" value="@ViewModel.CamadaEmEdicaoId" @onchange="TrocarCamadaEmEdicaoAsync">
                            @foreach (var camada in ViewModel.Camadas)
                            {
                                <option value="@camada.Id" disabled="@camada.Bloqueada">@camada.Nome@(camada.Bloqueada ? " (bloqueada)" : "")</option>
                            }
                        </select>
                    </div>
                    <div class="edicao-grupo">
                        <button class="@FerramentaClasse(FerramentaDesenhoWeb.Lapis)" @onclick="() => AlternarFerramenta(FerramentaDesenhoWeb.Lapis)">✏️ Lápis</button>
                        <button class="@FerramentaClasse(FerramentaDesenhoWeb.Texto)" @onclick="() => AlternarFerramenta(FerramentaDesenhoWeb.Texto)">🔤 Texto</button>
                        <button class="@FerramentaClasse(FerramentaDesenhoWeb.Icone)" @onclick="AlternarMenuIcones">🧩 Ícones</button>
                        <button class="@FerramentaClasse(FerramentaDesenhoWeb.Cota)" @onclick="() => AlternarFerramenta(FerramentaDesenhoWeb.Cota)">🔍 Cota</button>
                    </div>

                    @if (_canvasEdicao is { ProcessandoOcr: true })
                    {
                        <!-- OCR local (Tesseract.js/WASM) leva alguns segundos de verdade — sem isto
                             parecia que a ferramenta tinha travado (delay reportado). -->
                        <span class="edicao-status-ocr">🔎 Reconhecendo texto...</span>
                    }

                    @if (_ferramenta == FerramentaDesenhoWeb.Lapis)
                    {
                        <div class="edicao-grupo">
                            <select @bind="_estiloLinha">
                                <option value="@EstiloTracoWeb.Livre">Livre</option>
                                <option value="@EstiloTracoWeb.RetaContinua">Reta contínua</option>
                                <option value="@EstiloTracoWeb.RetaPontilhada">Reta pontilhada</option>
                                <option value="@EstiloTracoWeb.RetaTracejada">Reta tracejada</option>
                            </select>
                            <button class="@(ViewModel.ModoApagar ? "ativo" : "")" @onclick="() => ViewModel.ModoApagar = !ViewModel.ModoApagar" title="Borracha">🧽</button>
                            @if (ViewModel.PermiteEscolherCor)
                            {
                                <input type="color" @bind="ViewModel.CorTraco" title="Cor" />
                            }
                            <input type="range" min="1" max="@ViewModel.EspessuraMaxima" step="1" value="@ViewModel.EspessuraTraco.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                   @oninput="e => ViewModel.EspessuraTraco = float.Parse((string)e.Value!, System.Globalization.CultureInfo.InvariantCulture)" title="Espessura" />
                        </div>
                    }

                    @if (_mostrarMenuIcones)
                    {
                        <div class="edicao-grupo edicao-menu-icones">
                            @foreach (var (nomeArquivo, titulo) in IconeSvgCatalogoWeb.Icones)
                            {
                                <button title="@titulo" @onclick="() => SelecionarIconeAsync(nomeArquivo)">@titulo</button>
                            }
                        </div>
                    }

                    <div class="edicao-grupo">
                        <button disabled="@(_canvasEdicao is not { TemAcaoParaDesfazer: true })" @onclick="() => _canvasEdicao?.Desfazer()" title="Desfazer">↶</button>
                        <button disabled="@(_canvasEdicao is not { TemAcaoParaRefazer: true })" @onclick="() => _canvasEdicao?.Refazer()" title="Refazer">↷</button>
                        <button @onclick="LimparCamadaAtivaAsync" title="Limpar camada">🗑 Limpar</button>
                    </div>

                    @if (_canvasEdicao is { TemElementoPendente: true })
                    {
                        <div class="edicao-grupo">
                            @if (_canvasEdicao.TextoElementoPendente is not null)
                            {
                                <input class="edicao-texto-pendente" type="text" autofocus
                                       value="@_canvasEdicao.TextoElementoPendente"
                                       @oninput="e => _canvasEdicao?.DefinirTextoElementoPendente((string?)e.Value ?? string.Empty)"
                                       placeholder="Texto..." />
                            }
                            <button @onclick="() => _canvasEdicao?.RotacionarElementoPendente()" title="Girar">↻</button>
                            <button @onclick="() => _canvasEdicao?.RedimensionarElementoPendente(-4f)" title="Menor">A−</button>
                            <button @onclick="() => _canvasEdicao?.RedimensionarElementoPendente(4f)" title="Maior">A+</button>
                            <button @onclick="() => _canvasEdicao?.ConfirmarElementoPendente()" title="Confirmar">✓ Confirmar</button>
                            <button @onclick="() => _canvasEdicao?.CancelarElementoPendente()" title="Cancelar">✕ Cancelar</button>
                        </div>
                    }

                    <div class="edicao-grupo">
                        <button class="btn-salvar" @onclick="SalvarCamadaAtivaAsync">💾 Salvar</button>
                        <button @onclick="SairDaEdicaoAsync">Sair da edição</button>
                    </div>
                </div>
            }

            <!-- Wrapper com scroll: quando o zoom deixa a planta maior que a área visível, dá pra
                 percorrer com a barra de rolagem em vez de ficar cortada sem forma de ver o resto
                 (bug reportado: "não consigo visualizar a planta inteira"). -->
            <div class="planta-canvas-scroll" id="planta-canvas-wrapper">
                @if (ViewModel.ModoEdicao)
                {
                    <PlantaCanvasEdicaoWeb @ref="_canvasEdicao"
                                           ImagemBase="ViewModel.ImagemBase"
                                           Camadas="ViewModel.Camadas"
                                           ImagensPorCamada="ViewModel.ImagensPorCamada"
                                           CamadaAtivaId="ViewModel.CamadaEmEdicaoId"
                                           Zoom="_zoom"
                                           Ferramenta="_ferramenta"
                                           EstiloLinha="_estiloLinha"
                                           CorTraco="@ViewModel.CorTraco"
                                           EspessuraTraco="ViewModel.EspessuraTraco"
                                           ModoApagar="ViewModel.ModoApagar"
                                           IconeAtivo="_iconeAtivo"
                                           OcrService="OcrService"
                                           OnDesenhoAlterado="OnDesenhoAlterado" />
                }
                else
                {
                    <!-- SkiaSharp.Views.Blazor.SKCanvasView não tem WidthRequest/HeightRequest (isso só
                         existe na versão MAUI) — vira atributo HTML sem efeito, e o canvas caía no
                         tamanho padrão 300x150, cortando a planta. Tamanho real vem do "style" (CSS),
                         que o componente observa via ResizeObserver. -->
                    <SKCanvasView @ref="_canvasView"
                                  style="@EstiloCanvasNormal"
                                  OnPaintSurface="Desenhar" />
                }
            </div>
        }
        else if (ViewModel.EstaCarregando)
        {
            <p><em>Carregando planta...</em></p>
        }
    </div>

    <div class="planta-camadas-area">
        <div class="camadas-cabecalho">
            <h5>Camadas</h5>
            <!-- Antes não existia NENHUMA forma de criar uma camada nova pela Web (só "Ícones" era
                 criada sozinha) — pedido do usuário. -->
            <button class="camadas-botao-nova" title="Nova camada" @onclick="() => _mostrarFormNovaCamada = !_mostrarFormNovaCamada">+ Nova</button>
        </div>

        @if (_mostrarFormNovaCamada)
        {
            <div class="camadas-form-nova">
                <input type="text" placeholder="Nome da camada" @bind="_nomeNovaCamada" @bind:event="oninput"
                       @onkeydown="@(e => e.Key == "Enter" ? CriarCamadaAsync() : Task.CompletedTask)" />
                <button @onclick="CriarCamadaAsync" disabled="@string.IsNullOrWhiteSpace(_nomeNovaCamada)">Criar</button>
            </div>
        }

        <div class="camadas-painel">
            @foreach (var camada in ViewModel.Camadas)
            {
                <div class="camada-linha @(ViewModel.ModoEdicao && ViewModel.CamadaAtiva?.Id == camada.Id ? "camada-em-edicao" : "")">
                    <!-- Olho: sempre mostra um glifo (aberto/fechado) pra continuar visível e clicável mesmo
                         com a camada oculta — antes sumia por completo e ficava impossível achar o botão
                         pra reexibir a camada (bug reportado). -->
                    <button class="camada-icone" title="@(camada.Visivel ? "Ocultar" : "Mostrar")" @onclick="() => AlternarVisibilidadeAsync(camada)">
                        @(camada.Visivel ? "👁" : "🚫")
                    </button>

                    <div class="camada-miniatura">
                        @{ var miniatura = MiniaturaCamada(camada.Id); }
                        @if (miniatura is not null)
                        {
                            <img src="@miniatura" alt="" />
                        }
                    </div>

                    <div class="camada-info">
                        <span class="camada-nome" title="@camada.Nome">
                            @camada.Nome
                            @if (camada.Bloqueada)
                            {
                                <span class="camada-cadeado-inline">🔒</span>
                            }
                        </span>
                        <input class="camada-opacidade" type="range" min="0" max="1" step="0.05"
                               value="@camada.Opacidade.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               title="Opacidade"
                               @onchange="e => DefinirOpacidadeAsync(camada, e.Value)" />
                    </div>

                    <button class="camada-icone" title="Desenhar nesta camada" disabled="@camada.Bloqueada" @onclick="() => EditarCamadaAsync(camada)">✏️</button>

                    <button class="camada-icone camada-cadeado" title="@(camada.Bloqueada ? "Desbloquear" : "Bloquear")" @onclick="() => AlternarBloqueioAsync(camada)">
                        @(camada.Bloqueada ? "🔒" : "🔓")
                    </button>

                    <div class="camada-ordem">
                        <button class="camada-seta" @onclick="() => MoverAsync(camada, paraCima: true)">▲</button>
                        <button class="camada-seta" @onclick="() => MoverAsync(camada, paraCima: false)">▼</button>
                    </div>

                    <button class="camada-icone camada-excluir" title="Excluir camada" @onclick="() => ExcluirCamadaAsync(camada)">🗑</button>
                </div>
            }
        </div>
    </div>
</div>

@if (_telaCheia && ViewModel.ImagemBase is not null)
{
    <!-- Visualização ampliada dentro do próprio site (sem navegar pra outra página): ocupa a tela
         toda por cima do conteúdo, com seu próprio "ajustar à tela" calculado pelo tamanho real do
         viewport (JS interop), em vez da estimativa fixa usada no painel lateral. A tela cheia
         permanece só de visualização mesmo durante a edição — desenhar fica no painel normal. -->
    <div class="planta-fullscreen-overlay" @onclick="FecharTelaCheia">
        <div class="planta-fullscreen-conteudo" @onclick:stopPropagation="true">
            <div class="planta-zoom-controles planta-fullscreen-controles">
                <span>Zoom</span>
                <button @onclick="() => AjustarZoom(_zoom - 0.25)">−</button>
                <input type="range" min="@ZoomMinimo.ToString(System.Globalization.CultureInfo.InvariantCulture)" max="3" step="0.01" value="@_zoom.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                       @oninput="e => AjustarZoom(double.Parse((string)e.Value!, System.Globalization.CultureInfo.InvariantCulture))" />
                <button @onclick="() => AjustarZoom(_zoom + 0.25)">+</button>
                <span class="planta-zoom-valor">@($"{_zoom:P0}")</span>
                <button @onclick="() => AjustarZoomParaTelaAsync(telaCheia: true)">Ajustar à tela</button>
                <button @onclick="FecharTelaCheia" title="Fechar">✕ Fechar</button>
            </div>
            <div class="planta-canvas-scroll planta-fullscreen-scroll" id="planta-fullscreen-wrapper">
                <SKCanvasView @ref="_canvasViewTelaCheia"
                              style="@EstiloCanvasNormal"
                              OnPaintSurface="Desenhar" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid PlantaId { get; set; }

    private SKCanvasView? _canvasView;
    private SKCanvasView? _canvasViewTelaCheia;
    private PlantaCanvasEdicaoWeb? _canvasEdicao;
    private double _zoom = 1.0;
    private DotNetObjectReference<Planta>? _dotNetRef;

    // Atributos de componente Razor (SKCanvasView é componente, não elemento HTML puro) não aceitam
    // markup+expressão misturados no mesmo valor de atributo — "style" precisa vir de uma única
    // expressão. Ver comentário completo sobre a ausência de WidthRequest/HeightRequest no Blazor.
    private string EstiloCanvasNormal => ViewModel.ImagemBase is { } imagemBase
        ? $"width:{(int)(imagemBase.Width * _zoom)}px; height:{(int)(imagemBase.Height * _zoom)}px;"
        : string.Empty;

    private bool _zoomAjustadoNoCarregamento;
    private bool _telaCheia;
    private bool? _ajusteZoomPendentePara;

    // Nullable de propósito: null = nenhuma ferramenta ativa (clicar na planta não faz nada). Antes
    // era sempre uma ferramenta (Lápis por padrão) e não dava pra "desligar" nenhuma — pedido do
    // usuário: clicar na ferramenta já ativa desativa em vez de ficar presa selecionada pra sempre.
    private FerramentaDesenhoWeb? _ferramenta;
    private EstiloTracoWeb _estiloLinha = EstiloTracoWeb.Livre;
    private bool _mostrarMenuIcones;
    private (SKPicture Picture, string NomeArquivo)? _iconeAtivo;
    private bool _mostrarFormNovaCamada;
    private string _nomeNovaCamada = string.Empty;

    /// <summary>Largura aproximada usada só como fallback caso a medição via JS interop falhe
    /// (ex.: elemento ainda não presente no DOM).</summary>
    private const double LarguraColunaAproximada = 900;

    /// <summary>Zoom mínimo permitido. Precisa ser bem baixo porque plantas/capturas de tela de
    /// celular são bem maiores (em pixels) que a área de exibição — um piso de 25% (valor antigo)
    /// impedia enquadrar imagens grandes por completo, cortando a base da imagem sem dar pra ver o
    /// resto (bug reportado: "mesmo com o zoom mínimo não consigo visualizar a imagem por completo").</summary>
    private const double ZoomMinimo = 0.02;

    private sealed record TamanhoElemento(double Width, double Height);

    protected override async Task OnInitializedAsync()
    {
        ViewModel.PropertyChanged += AoPropriedadeMudar;
        await ViewModel.CarregarAsync(PlantaId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Primeiro carregamento: começa com a planta inteira visível (em vez do tamanho nativo, que
        // geralmente é maior que a tela e cortava a visualização — bug reportado). Só roda depois do
        // primeiro render pra garantir que o elemento já existe no DOM e a medição via JS funcione.
        if (!_zoomAjustadoNoCarregamento && ViewModel.ImagemBase is not null)
        {
            _zoomAjustadoNoCarregamento = true;
            await AjustarZoomParaTelaAsync(telaCheia: false);
        }

        if (_ajusteZoomPendentePara is { } telaCheiaAlvo)
        {
            _ajusteZoomPendentePara = null;
            await AjustarZoomParaTelaAsync(telaCheiaAlvo);
            (telaCheiaAlvo ? _canvasViewTelaCheia : _canvasView)?.Invalidate();
        }

        if (ViewModel.ImagemBase is not null)
        {
            await JS.InvokeVoidAsync("camdasInterop.habilitarArrastarPan", "planta-canvas-wrapper");
            await JS.InvokeVoidAsync("camdasInterop.definirModoDesenho", "planta-canvas-wrapper", ViewModel.ModoEdicao);
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("camdasInterop.habilitarZoomCtrlScroll", "planta-canvas-wrapper", _dotNetRef);
            await JS.InvokeVoidAsync("camdasInterop.habilitarAtalhosTeclado", _dotNetRef);
            if (_telaCheia)
            {
                await JS.InvokeVoidAsync("camdasInterop.habilitarArrastarPan", "planta-fullscreen-wrapper");
                await JS.InvokeVoidAsync("camdasInterop.habilitarZoomCtrlScroll", "planta-fullscreen-wrapper", _dotNetRef);
            }
        }
    }

    /// <summary>ESC como "coringa" pra voltar/cancelar (pedido do usuário) — desfaz o estado mais
    /// "interno" primeiro, na ordem que faz mais sentido pro usuário (o que está mais em foco agora):
    /// elemento pendente solto > menu de ícones/form de nova camada abertos > ferramenta selecionada >
    /// tela cheia > modo de edição (volta pra visualização). Só age em UM desses por vez — apertar de
    /// novo continua "voltando" um passo a cada vez, em vez de sair tudo de uma vez.</summary>
    [JSInvokable]
    public void OnTeclaEsc()
    {
        if (_canvasEdicao is { TemElementoPendente: true })
        {
            _canvasEdicao.CancelarElementoPendente();
            return;
        }

        if (_mostrarMenuIcones)
        {
            _mostrarMenuIcones = false;
            StateHasChanged();
            return;
        }

        if (_mostrarFormNovaCamada)
        {
            _mostrarFormNovaCamada = false;
            StateHasChanged();
            return;
        }

        if (_ferramenta is not null)
        {
            _ferramenta = null;
            StateHasChanged();
            return;
        }

        if (_telaCheia)
        {
            FecharTelaCheia();
            return;
        }

        if (ViewModel.ModoEdicao)
            _ = SairDaEdicaoAsync();
    }

    /// <summary>Ctrl+Z — pedido do usuário (atalho de desktop pra desfazer). Ignorado enquanto o foco
    /// está num campo de texto (ver camdasInterop.habilitarAtalhosTeclado): senão roubaria o desfazer
    /// NATIVO de digitação do próprio campo (texto pendente, nome de camada nova).</summary>
    [JSInvokable]
    public void OnAtalhoDesfazer()
    {
        if (_canvasEdicao is { TemAcaoParaDesfazer: true })
            _canvasEdicao.Desfazer();
    }

    /// <summary>Ctrl+Y / Ctrl+Shift+Z — refazer, par natural do Ctrl+Z acima.</summary>
    [JSInvokable]
    public void OnAtalhoRefazer()
    {
        if (_canvasEdicao is { TemAcaoParaRefazer: true })
            _canvasEdicao.Refazer();
    }

    /// <summary>Chamado pelo JS (camdasInterop.habilitarZoomCtrlScroll) a cada "wheel" com Ctrl
    /// pressionado — equivalente desktop da pinça de zoom (não existe no mouse). deltaY negativo é
    /// "rodinha pra cima"/afastar os dedos (zoom in); positivo é o contrário.</summary>
    [JSInvokable]
    public void OnCtrlScrollZoom(double deltaY)
    {
        var multiplicador = deltaY < 0 ? 1.1 : 1.0 / 1.1;
        AjustarZoom(_zoom * multiplicador);
    }

    private void Desenhar(SKPaintSurfaceEventArgs args)
    {
        var canvas = args.Surface.Canvas;
        canvas.Clear(SKColors.White);
        canvas.Save();
        canvas.Scale((float)_zoom);
        PlantaOverlayRenderer.Desenhar(canvas, ViewModel.Camadas, ViewModel.ImagemBase, ViewModel.ImagensPorCamada);
        canvas.Restore();
    }

    private void AjustarZoom(double zoom)
    {
        _zoom = Math.Clamp(zoom, ZoomMinimo, 3.0);
        StateHasChanged();
        InvokeAsync(() =>
        {
            _canvasView?.Invalidate();
            _canvasViewTelaCheia?.Invalidate();
            _canvasEdicao?.Invalidar();
        });
    }

    /// <summary>Mede via JS interop o tamanho real do container (coluna lateral ou overlay de tela
    /// cheia) e calcula o zoom que preenche o MAIOR dos dois eixos (largura ou altura) — não só a
    /// largura como antes: pra plantas bem largas em pixels (fotos/scans de alta resolução), ajustar
    /// só pela largura dava um zoom minúsculo (2% no bug reportado, "amplie a área de visualização"),
    /// murchando a área inteira mesmo sobrando bastante altura livre na tela. Usando o maior dos dois
    /// eixos, a planta aparece o maior possível e o eixo que não couber fica disponível via scroll do
    /// próprio wrapper (o wrapper agora tem altura FIXA em vez de max-height, senão essa medição vira
    /// circular: a altura do container dependeria do zoom atual, que é justamente o que estamos
    /// calculando).</summary>
    private async Task AjustarZoomParaTelaAsync(bool telaCheia)
    {
        if (ViewModel.ImagemBase is not { } imagemBase || imagemBase.Width <= 0 || imagemBase.Height <= 0)
            return;

        var elementId = telaCheia ? "planta-fullscreen-wrapper" : "planta-canvas-wrapper";
        TamanhoElemento? tamanho = null;
        try
        {
            tamanho = await JS.InvokeAsync<TamanhoElemento?>("camdasInterop.getElementSize", elementId);
        }
        catch (JSException)
        {
            // Elemento ainda não disponível no DOM — usa o fallback abaixo.
        }

        var larguraDisponivel = tamanho is { Width: > 0 } ? tamanho.Width : LarguraColunaAproximada;
        var alturaDisponivel = tamanho is { Height: > 0 } ? tamanho.Height : larguraDisponivel;

        var zoomPorLargura = larguraDisponivel / imagemBase.Width;
        var zoomPorAltura = alturaDisponivel / imagemBase.Height;
        AjustarZoom(Math.Min(1.0, Math.Max(zoomPorLargura, zoomPorAltura)));
    }

    private void AbrirTelaCheia()
    {
        _telaCheia = true;
        _ajusteZoomPendentePara = true;
    }

    private void FecharTelaCheia()
    {
        _telaCheia = false;
        _ajusteZoomPendentePara = false;
    }

    private async Task AlternarVisibilidadeAsync(BellucSketch.Contracts.CamadaDto camada)
    {
        await ViewModel.AlternarVisibilidadeCommand.ExecuteAsync(camada);
        _canvasView?.Invalidate();
    }

    private async Task AlternarBloqueioAsync(BellucSketch.Contracts.CamadaDto camada) =>
        await ViewModel.AlternarBloqueioCommand.ExecuteAsync(camada);

    /// <summary>Web não tem arrastar-e-soltar (Mobile trocou pra isso) — reaproveita
    /// ReordenarArrastandoAsync "movendo" a camada pra posição da vizinha imediata.</summary>
    private async Task MoverAsync(BellucSketch.Contracts.CamadaDto camada, bool paraCima)
    {
        var indice = ViewModel.Camadas.IndexOf(camada);
        var indiceVizinho = paraCima ? indice - 1 : indice + 1;
        if (indice < 0 || indiceVizinho < 0 || indiceVizinho >= ViewModel.Camadas.Count)
            return;

        await ViewModel.ReordenarArrastandoAsync(camada, ViewModel.Camadas[indiceVizinho]);
    }

    private async Task DefinirOpacidadeAsync(BellucSketch.Contracts.CamadaDto camada, object? valor)
    {
        if (valor is not string texto || !double.TryParse(texto, System.Globalization.CultureInfo.InvariantCulture, out var opacidade))
            return;

        await ViewModel.DefinirOpacidadeAsync(camada, opacidade);
        _canvasView?.Invalidate();
    }

    private async Task ExcluirCamadaAsync(BellucSketch.Contracts.CamadaDto camada)
    {
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"Excluir a camada '{camada.Nome}'? O traço dela some, sem volta.");
        if (!confirmar)
            return;

        await ViewModel.RemoverCamadaAsync(camada);
        _miniaturaCache.Remove(camada.Id);
        _canvasView?.Invalidate();
    }

