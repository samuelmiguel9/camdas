    private void AlternarMenuIcones()
    {
        if (_ferramenta == FerramentaDesenhoWeb.Icone)
        {
            // Já ativa: desliga a ferramenta E fecha o menu (mesmo comportamento de toggle das outras).
            _canvasEdicao?.CancelarElementoPendente();
            _ferramenta = null;
            _mostrarMenuIcones = false;
            return;
        }

        _canvasEdicao?.CancelarElementoPendente();
        _ferramenta = FerramentaDesenhoWeb.Icone;
        _mostrarMenuIcones = true;
    }

