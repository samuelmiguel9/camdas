<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>BellucSketch.Mobile</RootNamespace>
    <!-- Biblioteca plain .NET (não net8.0-android) de propósito: ViewModels, o cliente HTTP e a
         lógica de desenho (SkiaSharp) ficam aqui para poderem ser testados num host xUnit comum,
         sem precisar de emulador Android nem do workload MAUI. O app BellucSketch.Mobile (net8.0-android)
         referencia este projeto e só adiciona a "casca" de UI (XAML, Platforms/, MauiProgram.cs). -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />
    <PackageReference Include="SkiaSharp" Version="3.119.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BellucSketch.Domain\BellucSketch.Domain.csproj" />
    <ProjectReference Include="..\BellucSketch.Contracts\BellucSketch.Contracts.csproj" />
  </ItemGroup>

  <!-- Mesmo VERSION lido pelo BellucSketch.Mobile.csproj (ApplicationDisplayVersion) e pelo
       BellucSketch.Api (endpoint /version) — fonte única pra evitar a Api e o Apk divulgarem números de
       versão divergentes. -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\VERSION" LogicalName="VERSION" />
  </ItemGroup>

</Project>
