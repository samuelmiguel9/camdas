<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BellucSketch.Mobile"
             xmlns:conv="clr-namespace:BellucSketch.Mobile.Converters"
             x:Class="BellucSketch.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <conv:StringNaoVazioParaBoolConverter x:Key="StringNaoVazioParaBoolConverter" />
            <conv:BoolParaTextoConverter x:Key="BoolParaTextoConverter" />
            <conv:ObjetoNuloParaBoolConverter x:Key="ObjetoNuloParaBoolConverter" />
            <conv:BytesParaImageSourceConverter x:Key="BytesParaImageSourceConverter" />
            <conv:CamadaAtivaParaCorConverter x:Key="CamadaAtivaParaCorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
