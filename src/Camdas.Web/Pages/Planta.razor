@page "/plantas/{PlantaId:guid}"
@using Camdas.Mobile.Rendering
@using Camdas.Mobile.ViewModels
@implements IDisposable
@inject PlantaViewModel ViewModel
@inject IJSRuntime JS
@using SkiaSharp
@using SkiaSharp.Views.Blazor

<PageTitle>@(ViewModel.Planta?.Nome ?? "Planta") — Camdas</PageTitle>

<h1>@(ViewModel.Planta?.Nome ?? "Carregando...")</h1>

@if (ViewModel.MensagemErro is not null)
{
    <p class="text-danger">@ViewModel.MensagemErro</p>
}

<div class="planta-layout">
    <div class="planta-area">
        @if (ViewModel.ImagemBase is not null)
        {
            <div class="planta-zoom-controles">
                <span>Zoom</span>
                <button @onclick="() => AjustarZoom(_zoom - 0.25)">−</button>
                <input type="range" min="@ZoomMinimo.ToString(System.Globalization.CultureInfo.InvariantCulture)" max="3" step="0.01" value="@_zoom.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                       @oninput="e => AjustarZoom(double.Parse((string)e.Value!, System.Globalization.CultureInfo.InvariantCulture))" />
                <button @onclick="() => AjustarZoom(_zoom + 0.25)">+</button>
                <span class="planta-zoom-valor">@($"{_zoom:P0}")</span>
                <button @onclick="() => AjustarZoomParaTelaAsync(telaCheia: false)">Ajustar à tela</button>
                <button @onclick="AbrirTelaCheia" title="Abrir em tela cheia">⛶ Ampliar</button>
            </div>

            <!-- Wrapper com scroll: quando o zoom deixa a planta maior que a área visível, dá pra
                 percorrer com a barra de rolagem em vez de ficar cortada sem forma de ver o resto
                 (bug reportado: "não consigo visualizar a planta inteira"). -->
            <div class="planta-canvas-scroll" id="planta-canvas-wrapper">
                <SKCanvasView @ref="_canvasView"
                              WidthRequest="@((int)(ViewModel.ImagemBase.Width * _zoom))"
                              HeightRequest="@((int)(ViewModel.ImagemBase.Height * _zoom))"
                              OnPaintSurface="Desenhar" />
            </div>
        }
        else if (ViewModel.EstaCarregando)
        {
            <p><em>Carregando planta...</em></p>
        }
    </div>

    <div class="planta-camadas-area">
        <h5>Camadas</h5>

        @{ var edicaoDeOrdem = EdicaoPendente(null); }
        @if (edicaoDeOrdem is not null)
        {
            <p class="camada-pendente-aviso" title="@DetalhesEdicaoPendente(edicaoDeOrdem)">
                ⏳ Reordenação pendente de aprovação no Android
            </p>
        }

        <div class="camadas-painel">
            @foreach (var camada in ViewModel.Camadas)
            {
                var edicaoPendente = EdicaoPendente(camada.Id);
                <div class="camada-linha">
                    <!-- Olho: sempre mostra um glifo (aberto/fechado) pra continuar visível e clicável mesmo
                         com a camada oculta — antes sumia por completo e ficava impossível achar o botão
                         pra reexibir a camada (bug reportado). -->
                    <button class="camada-icone" title="@(camada.Visivel ? "Ocultar" : "Mostrar")" @onclick="() => AlternarVisibilidadeAsync(camada)">
                        @(camada.Visivel ? "👁" : "🚫")
                    </button>

                    <div class="camada-miniatura">
                        @{ var miniatura = MiniaturaCamada(camada.Id); }
                        @if (miniatura is not null)
                        {
                            <img src="@miniatura" alt="" />
                        }
                    </div>

                    <div class="camada-info">
                        <span class="camada-nome" title="@camada.Nome">
                            @camada.Nome
                            @if (camada.Bloqueada)
                            {
                                <span class="camada-cadeado-inline">🔒</span>
                            }
                            @if (edicaoPendente is not null)
                            {
                                <span class="camada-pendente-inline" title="@DetalhesEdicaoPendente(edicaoPendente)">⏳</span>
                            }
                        </span>
                        <input class="camada-opacidade" type="range" min="0" max="1" step="0.05"
                               value="@camada.Opacidade.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               title="Opacidade"
                               @onchange="e => DefinirOpacidadeAsync(camada, e.Value)" />
                    </div>

                    <button class="camada-icone camada-cadeado" title="@(camada.Bloqueada ? "Desbloquear" : "Bloquear")" @onclick="() => AlternarBloqueioAsync(camada)">
                        @(camada.Bloqueada ? "🔒" : "🔓")
                    </button>

                    <div class="camada-ordem">
                        <button class="camada-seta" @onclick="() => MoverAsync(camada, paraCima: true)">▲</button>
                        <button class="camada-seta" @onclick="() => MoverAsync(camada, paraCima: false)">▼</button>
                    </div>

                    <button class="camada-icone camada-excluir" title="Excluir camada" @onclick="() => ExcluirCamadaAsync(camada)">🗑</button>
                </div>
            }
        </div>
    </div>
</div>

@if (_telaCheia && ViewModel.ImagemBase is not null)
{
    <!-- Visualização ampliada dentro do próprio site (sem navegar pra outra página): ocupa a tela
         toda por cima do conteúdo, com seu próprio "ajustar à tela" calculado pelo tamanho real do
         viewport (JS interop), em vez da estimativa fixa usada no painel lateral. -->
    <div class="planta-fullscreen-overlay" @onclick="FecharTelaCheia">
        <div class="planta-fullscreen-conteudo" @onclick:stopPropagation="true">
            <div class="planta-zoom-controles planta-fullscreen-controles">
                <span>Zoom</span>
                <button @onclick="() => AjustarZoom(_zoom - 0.25)">−</button>
                <input type="range" min="@ZoomMinimo.ToString(System.Globalization.CultureInfo.InvariantCulture)" max="3" step="0.01" value="@_zoom.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                       @oninput="e => AjustarZoom(double.Parse((string)e.Value!, System.Globalization.CultureInfo.InvariantCulture))" />
                <button @onclick="() => AjustarZoom(_zoom + 0.25)">+</button>
                <span class="planta-zoom-valor">@($"{_zoom:P0}")</span>
                <button @onclick="() => AjustarZoomParaTelaAsync(telaCheia: true)">Ajustar à tela</button>
                <button @onclick="FecharTelaCheia" title="Fechar">✕ Fechar</button>
            </div>
            <div class="planta-canvas-scroll planta-fullscreen-scroll" id="planta-fullscreen-wrapper">
                <SKCanvasView @ref="_canvasViewTelaCheia"
                              WidthRequest="@((int)(ViewModel.ImagemBase.Width * _zoom))"
                              HeightRequest="@((int)(ViewModel.ImagemBase.Height * _zoom))"
                              OnPaintSurface="Desenhar" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid PlantaId { get; set; }

    private SKCanvasView? _canvasView;
    private SKCanvasView? _canvasViewTelaCheia;
    private double _zoom = 1.0;
    private bool _zoomAjustadoNoCarregamento;
    private bool _telaCheia;
    private bool? _ajusteZoomPendentePara;

    /// <summary>Largura aproximada usada só como fallback caso a medição via JS interop falhe
    /// (ex.: elemento ainda não presente no DOM).</summary>
    private const double LarguraColunaAproximada = 900;

    /// <summary>Zoom mínimo permitido. Precisa ser bem baixo porque plantas/capturas de tela de
    /// celular são bem maiores (em pixels) que a área de exibição — um piso de 25% (valor antigo)
    /// impedia enquadrar imagens grandes por completo, cortando a base da imagem sem dar pra ver o
    /// resto (bug reportado: "mesmo com o zoom mínimo não consigo visualizar a imagem por completo").</summary>
    private const double ZoomMinimo = 0.02;

    private sealed record TamanhoElemento(double Width, double Height);

    protected override async Task OnInitializedAsync()
    {
        ViewModel.PropertyChanged += AoPropriedadeMudar;
        await ViewModel.CarregarAsync(PlantaId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Primeiro carregamento: começa com a planta inteira visível (em vez do tamanho nativo, que
        // geralmente é maior que a tela e cortava a visualização — bug reportado). Só roda depois do
        // primeiro render pra garantir que o elemento já existe no DOM e a medição via JS funcione.
        if (!_zoomAjustadoNoCarregamento && ViewModel.ImagemBase is not null)
        {
            _zoomAjustadoNoCarregamento = true;
            await AjustarZoomParaTelaAsync(telaCheia: false);
        }

        if (_ajusteZoomPendentePara is { } telaCheiaAlvo)
        {
            _ajusteZoomPendentePara = null;
            await AjustarZoomParaTelaAsync(telaCheiaAlvo);
            (telaCheiaAlvo ? _canvasViewTelaCheia : _canvasView)?.Invalidate();
        }

        if (ViewModel.ImagemBase is not null)
        {
            await JS.InvokeVoidAsync("camdasInterop.habilitarArrastarPan", "planta-canvas-wrapper");
            if (_telaCheia)
                await JS.InvokeVoidAsync("camdasInterop.habilitarArrastarPan", "planta-fullscreen-wrapper");
        }
    }

    private void Desenhar(SKPaintSurfaceEventArgs args)
    {
        var canvas = args.Surface.Canvas;
        canvas.Clear(SKColors.White);
        canvas.Save();
        canvas.Scale((float)_zoom);
        PlantaOverlayRenderer.Desenhar(canvas, ViewModel.Camadas, ViewModel.ImagemBase, ViewModel.ImagensPorCamada);
        canvas.Restore();
    }

    private void AjustarZoom(double zoom)
    {
        _zoom = Math.Clamp(zoom, ZoomMinimo, 3.0);
        StateHasChanged();
        InvokeAsync(() =>
        {
            _canvasView?.Invalidate();
            _canvasViewTelaCheia?.Invalidate();
        });
    }

    /// <summary>Mede via JS interop a largura real do container (coluna lateral ou overlay de tela
    /// cheia) pra calcular o zoom que preenche a largura disponível — só a largura, igual ao app
    /// Android (PlantaPage.AjustarZoomParaTela): encaixar também a altura deixava o zoom minúsculo
    /// pra plantas altas, com metade da tela ociosa (bug reportado: "aumente" a visualização). O
    /// excesso de altura, se houver, é resolvido com o scroll do próprio wrapper.</summary>
    private async Task AjustarZoomParaTelaAsync(bool telaCheia)
    {
        if (ViewModel.ImagemBase is not { } imagemBase || imagemBase.Width <= 0)
            return;

        var elementId = telaCheia ? "planta-fullscreen-wrapper" : "planta-canvas-wrapper";
        TamanhoElemento? tamanho = null;
        try
        {
            tamanho = await JS.InvokeAsync<TamanhoElemento?>("camdasInterop.getElementSize", elementId);
        }
        catch (JSException)
        {
            // Elemento ainda não disponível no DOM — usa o fallback abaixo.
        }

        var larguraDisponivel = tamanho is { Width: > 0 } ? tamanho.Width : LarguraColunaAproximada;
        AjustarZoom(Math.Min(1.0, larguraDisponivel / imagemBase.Width));
    }

    private void AbrirTelaCheia()
    {
        _telaCheia = true;
        _ajusteZoomPendentePara = true;
    }

    private void FecharTelaCheia()
    {
        _telaCheia = false;
        _ajusteZoomPendentePara = false;
    }

    private async Task AlternarVisibilidadeAsync(Camdas.Contracts.CamadaDto camada)
    {
        await ViewModel.AlternarVisibilidadeCommand.ExecuteAsync(camada);
        _canvasView?.Invalidate();
    }

    private async Task AlternarBloqueioAsync(Camdas.Contracts.CamadaDto camada) =>
        await ViewModel.AlternarBloqueioCommand.ExecuteAsync(camada);

    /// <summary>Web não tem arrastar-e-soltar (Mobile trocou pra isso) — reaproveita
    /// ReordenarArrastandoAsync "movendo" a camada pra posição da vizinha imediata.</summary>
    private async Task MoverAsync(Camdas.Contracts.CamadaDto camada, bool paraCima)
    {
        var indice = ViewModel.Camadas.IndexOf(camada);
        var indiceVizinho = paraCima ? indice - 1 : indice + 1;
        if (indice < 0 || indiceVizinho < 0 || indiceVizinho >= ViewModel.Camadas.Count)
            return;

        await ViewModel.ReordenarArrastandoAsync(camada, ViewModel.Camadas[indiceVizinho]);
    }

    private async Task DefinirOpacidadeAsync(Camdas.Contracts.CamadaDto camada, object? valor)
    {
        if (valor is not string texto || !double.TryParse(texto, System.Globalization.CultureInfo.InvariantCulture, out var opacidade))
            return;

        await ViewModel.DefinirOpacidadeAsync(camada, opacidade);
        _canvasView?.Invalidate();
    }

    private async Task ExcluirCamadaAsync(Camdas.Contracts.CamadaDto camada)
    {
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"Excluir a camada '{camada.Nome}'? O traço dela some, sem volta.");
        if (!confirmar)
            return;

        await ViewModel.RemoverCamadaAsync(camada);
        _canvasView?.Invalidate();
    }

    /// <summary>Miniatura em xadrez (indica transparência) + traço da camada, mantendo proporção — mesmo espírito visual do painel de camadas do Photoshop.</summary>
    private string? MiniaturaCamada(Guid camadaId)
    {
        if (!ViewModel.ImagensPorCamada.TryGetValue(camadaId, out var bitmap))
            return null;

        const int tamanho = 32;
        var escala = (float)tamanho / Math.Max(bitmap.Width, bitmap.Height);
        using var reduzida = bitmap.Resize(
            new SKImageInfo(Math.Max(1, (int)(bitmap.Width * escala)), Math.Max(1, (int)(bitmap.Height * escala))),
            SKFilterQuality.Medium);
        if (reduzida is null)
            return null;

        using var imagem = SKImage.FromBitmap(reduzida);
        using var dados = imagem.Encode(SKEncodedImageFormat.Png, 90);
        return $"data:image/png;base64,{Convert.ToBase64String(dados.ToArray())}";
    }

    /// <summary>Primeira edição pendente para a camada (ou, com <paramref name="camadaId"/> nulo, a
    /// reordenação pendente que se aplica à planta inteira) — usada só pra exibir o aviso "⏳",
    /// aprovação de verdade só acontece no Android.</summary>
    private Camdas.Contracts.EdicaoPendenteDto? EdicaoPendente(Guid? camadaId) =>
        ViewModel.Planta?.EdicoesPendentes.FirstOrDefault(e => e.CamadaId == camadaId);

    private static string DetalhesEdicaoPendente(Camdas.Contracts.EdicaoPendenteDto edicao) =>
        $"Pendente de aprovação no Android — {edicao.Responsavel}, {edicao.DataSolicitacao:dd/MM/yyyy HH:mm}: {edicao.Motivo}";

    private void AoPropriedadeMudar(object? remetente, System.ComponentModel.PropertyChangedEventArgs args)
    {
        InvokeAsync(StateHasChanged);
        if (args.PropertyName == nameof(ViewModel.ImagemBase))
            InvokeAsync(() => _canvasView?.Invalidate());
    }

    public void Dispose() => ViewModel.PropertyChanged -= AoPropriedadeMudar;
}
